{
  "name": "melinda-ui-artikkelit",
  "type": "module",
  "version": "2.0.6-alpha.1",
  "description": "UI for Melinda Artikkelit application",
  "author": "The National Library of Finland",
  "license": "MIT",
  "keywords": [
    "artikkelit",
    "melinda",
    "natlibfi"
  ],
  "homepage": "https://github.com/NatLibFi/melinda-ui-artikkelit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NatLibFi/melinda-ui-artikkelit.git"
  },
  "bugs": {
    "url": "https://github.com/NatLibFi/melinda-ui-artikkelit/issues"
  },
  "main": "src/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "former-n22-build": "esbuild \"src/**/*.js\" --sourcemap --platform=node --outdir=dist",
    "build": "node build.js",
    "test:base": "node --test --test-force-exit --experimental-test-coverage --test-reporter=spec './tests/*.test.mjs' './tests/**/*.test.mjs'",
    "dev:test": "cross-env DEBUG=@natlibfi/* NODE_ENV=test node --watch --test --experimental-test-coverage --test-reporter=spec './tests/*.test.mjs' './tests/**/*.test.mjs'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "npm run lint && npm run test:base"
  },
  "dependencies": {
    "@natlibfi/marc-record": "^10.0.1",
    "@natlibfi/marc-record-validators-melinda": "^12.0.15",
    "@natlibfi/melinda-backend-commons": "^3.0.5",
    "@natlibfi/melinda-commons": "^14.0.2",
    "@natlibfi/melinda-rest-api-client": "^6.0.3",
    "@natlibfi/melinda-ui-commons": "^6.0.0",
    "@natlibfi/passport-melinda-aleph": "^4.0.0",
    "@natlibfi/passport-melinda-jwt": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.7",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "@natlibfi/fixugen": "^3.0.1",
    "@natlibfi/fixura": "^4.0.1",
    "eslint": "^10.2.0"
  }
}
